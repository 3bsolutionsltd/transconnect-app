# =============================================================
# TransConnect STAGING Environment Variables
# Location on VPS: /opt/transconnect/staging/.env
# =============================================================

# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=staging
DEMO_MODE=false

# ── Domain ────────────────────────────────────────────────────
FRONTEND_URL=https://staging.transconnect.app
ADMIN_URL=https://admin-staging.transconnect.app
CORS_ORIGINS=https://staging.transconnect.app,https://admin-staging.transconnect.app

# ── Database ──────────────────────────────────────────────────
# Strong random password — generate with: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_32

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_openssl_rand_hex_16

# ── JWT ───────────────────────────────────────────────────────
# At least 32 characters — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
JWT_EXPIRES_IN=30d

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.titan.email
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=transconnect@omande.net
SMTP_PASS=CHANGE_ME
EMAIL_HOST=smtp.titan.email
EMAIL_PORT=465
EMAIL_USER=transconnect@omande.net
EMAIL_PASS=CHANGE_ME

# ── Security Keys ────────────────────────────────────────────
# Generate with: openssl rand -hex 32
PAYMENT_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32
WEBHOOK_SECRET=CHANGE_ME_openssl_rand_hex_32

# ── OTP ──────────────────────────────────────────────────────
OTP_EXPIRY=300

# ── SMS (eSMS Africa — use test credentials) ─────────────────
ESMS_API_KEY=YOUR_ESMS_STAGING_API_KEY
ESMS_USERNAME=2057
ESMS_SENDER_ID=TransTest

# ── SMS (Twilio — international fallback) ────────────────────
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_PHONE_NUMBER=+17278882590

# ── Maps (OSRM — no API key required) ─────────────────────
# Using public OSRM + Nominatim — free, no billing needed
# GOOGLE_MAPS_API_KEY is not used

# ── Payments — SANDBOX ONLY ───────────────────────────────────
# ── Payments — SANDBOX/TEST KEYS ────────────────────────────
# PesaPal sandbox (https://cybqa.pesapal.com/pesapalv3)
PESAPAL_CONSUMER_KEY=YOUR_PESAPAL_SANDBOX_CONSUMER_KEY
PESAPAL_CONSUMER_SECRET=YOUR_PESAPAL_SANDBOX_CONSUMER_SECRET
PESAPAL_ENVIRONMENT=sandbox
PESAPAL_IPN_URL=https://staging-api.transconnect.app/api/payments/ipn/pesapal
PESAPAL_WEBHOOK_SECRET=CHANGE_ME_openssl_rand_hex_32

FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TESTxxxxxxxxxxxxxx

MTN_MOMO_SUBSCRIPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MTN_MOMO_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MTN_MOMO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

AIRTEL_MONEY_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AIRTEL_MONEY_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── React / Next.js build args ────────────────────────────────
REACT_APP_API_URL=https://api-staging.transconnect.app
NEXT_PUBLIC_API_URL=https://api-staging.transconnect.app/api
NEXT_PUBLIC_SOCKET_URL=https://api-staging.transconnect.app
NEXT_PUBLIC_SITE_URL=https://staging.transconnect.app
NEXT_PUBLIC_ADMIN_URL=https://admin-staging.transconnect.app
