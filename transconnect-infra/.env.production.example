# =============================================================
# TransConnect PRODUCTION Environment Variables
# Location on VPS: /opt/transconnect/production/.env
# =============================================================

# ── Domain ────────────────────────────────────────────────────
FRONTEND_URL=https://transconnect.app
ADMIN_URL=https://admin.transconnect.app
CORS_ORIGINS=https://transconnect.app,https://www.transconnect.app,https://admin.transconnect.app

# ── Database ──────────────────────────────────────────────────
# Strong random password — generate with: openssl rand -hex 32
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_32

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_openssl_rand_hex_16

# ── JWT ───────────────────────────────────────────────────────
# At least 64 characters — generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_openssl_rand_hex_64
JWT_EXPIRES_IN=7d

# ── SMS (eSMS Africa — use LIVE credentials) ──────────────────
ESMS_API_KEY=YOUR_ESMS_LIVE_API_KEY
ESMS_USERNAME=2057
ESMS_SENDER_ID=TransConnect

# ── Google Maps ───────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_PRODUCTION_KEY

# ── Payments — LIVE KEYS ──────────────────────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_LIVE-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_LIVE-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_LIVExxxxxxxxxxxxxx

MTN_MOMO_SUBSCRIPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MTN_MOMO_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MTN_MOMO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

AIRTEL_MONEY_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AIRTEL_MONEY_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── React / Next.js build args ────────────────────────────────
REACT_APP_API_URL=https://api.transconnect.app
NEXT_PUBLIC_API_URL=https://api.transconnect.app/api
NEXT_PUBLIC_SOCKET_URL=https://api.transconnect.app
NEXT_PUBLIC_SITE_URL=https://transconnect.app
NEXT_PUBLIC_ADMIN_URL=https://admin.transconnect.app
